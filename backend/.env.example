# trend-graph 后端环境变量样例
# 复制本文件为 .env，然后改为你的真实配置
# .env 已被 .gitignore 忽略，不会提交到 GitHub，请放心填密钥

# ============ 服务配置 ============
# HTTP 服务监听端口
PORT=8080

# ============ 数据库配置（阶段 2 启用）============
# PostgreSQL 连接串，格式: host=xxx port=xxx user=xxx password=xxx dbname=xxx sslmode=disable
DATABASE_URL=host=localhost port=5432 user=postgres password=postgres dbname=trend_graph sslmode=disable timezone=Asia/Shanghai

# ============ AI 配置（阶段 3 启用）============
# DeepSeek 官方 API Key，去 https://platform.deepseek.com 申请
DEEPSEEK_API_KEY=sk-你的key
# DeepSeek 模型选择：个人信号分析与内容生成默认使用 V4 Pro
DEEPSEEK_MODEL=deepseek-v4-pro
# DeepSeek API 地址（OpenAI 兼容协议）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============ 私有访问与采集配置 ============
# 必填。请使用高强度随机密码；只放在服务器环境变量中，绝不提交到仓库。
ADMIN_PASSWORD=replace-with-a-long-random-password
# 管理员会话有效期（小时）
ADMIN_SESSION_HOURS=168
# HTTPS 部署必须为 true；本地 HTTP 调试可显式改为 false。
SESSION_COOKIE_SECURE=true
# Python 采集器调用内部写入接口时使用的共享密钥（后续采集器启用时必填）
INTERNAL_INGEST_SECRET=replace-with-a-second-random-secret
# Go 服务启动目录为 backend 时的 Python 采集器路径；生产部署可改为绝对路径。
COLLECTOR_DIR=../services/collector
# GitHub token 可提高公开 REST API 限额；SkillsMP key 可选。
GITHUB_TOKEN=
SKILLSMP_API_KEY=
# Reddit 只使用官方 OAuth 和社区白名单；没有凭据时该来源应报告异常，不回退 r/all。
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_COMMUNITIES=r/LocalLLaMA,r/ClaudeAI,r/ClaudeCode,r/AI_Agents,r/cursor,r/ChatGPTCoding

# ============ 通知配置（阶段 7 启用）============
# 邮件 SMTP
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=你的邮箱@qq.com
SMTP_PASS=你的授权码
SMTP_FROM=你的邮箱@qq.com

# 飞书机器人 Webhook
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/你的token

# 钉钉机器人 Webhook
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=你的token
# 钉钉机器人加签密钥（如果勾选"加签"安全设置）
DINGTALK_SECRET=你的加签secret

# 邮件通知收件人（多收件人用逗号分隔）
SMTP_TO=你的邮箱@qq.com,friend@example.com

# ============ 爬虫配置（阶段 5 启用）============
# 抓取并发数
CRAWLER_CONCURRENCY=5
# 单次请求超时秒数
CRAWLER_TIMEOUT=10
