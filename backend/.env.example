# trend-graph 后端环境变量样例
# 复制本文件为 .env，然后改为你的真实配置
# .env 已被 .gitignore 忽略，不会提交到 GitHub，请放心填密钥

# ============ 服务配置 ============
# HTTP 服务监听端口
PORT=8080

# ============ 数据库配置（阶段 2 启用）============
# PostgreSQL 连接串，格式: host=xxx port=xxx user=xxx password=xxx dbname=xxx sslmode=disable
DATABASE_URL=host=localhost port=5432 user=postgres password=postgres dbname=trend_graph sslmode=disable timezone=Asia/Shanghai

# ============ AI 配置（阶段 3 启用）============
# DeepSeek 官方 API Key，去 https://platform.deepseek.com 申请
DEEPSEEK_API_KEY=sk-你的key
# DeepSeek 模型选择，deepseek-chat 性价比最高
DEEPSEEK_MODEL=deepseek-chat
# DeepSeek API 地址（OpenAI 兼容协议）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ============ 各信息源 API Key（按需，阶段 5 启用）============
# Twitter / X API，可选，没有就跳过 Twitter 源
TWITTER_API_KEY=
# Reddit API，可选，没填则用爬虫模式
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ============ 通知配置（阶段 7 启用）============
# 邮件 SMTP
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=你的邮箱@qq.com
SMTP_PASS=你的授权码
SMTP_FROM=你的邮箱@qq.com

# 飞书机器人 Webhook
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/你的token

# 钉钉机器人 Webhook
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=你的token

# ============ 爬虫配置（阶段 5 启用）============
# 抓取并发数
CRAWLER_CONCURRENCY=5
# 单次请求超时秒数
CRAWLER_TIMEOUT=10